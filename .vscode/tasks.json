{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Start Frontend Dev Server",
      "type": "shell",
      "command": "npm run dev",
      "options": {
        "cwd": "${workspaceFolder}/client"
      },
      "isBackground": true,
      "problemMatcher": [
        {
          "owner": "custom",
          "fileLocation": "absolute",
          "pattern": {
            "regexp": "^(.*)$",
            "file": 1,
            "location": 1,
            "message": 1
          },
          "background": {
            "activeOnStart": true,
            "beginsPattern": "^\\s*VITE\\s+v",
            "endsPattern": "Local:\\s+http://localhost:5173/"
          }
        }
      ],
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "clear": false
      }
    },
    {
      "label": "Start Backend Dev Server",
      "type": "shell",
      "command": "npm run dev",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "isBackground": true,
      "problemMatcher": [
        {
          "owner": "custom",
          "fileLocation": "absolute",
          "pattern": {
            "regexp": "^(.*)$",
            "file": 1,
            "location": 1,
            "message": 1
          },
          "background": {
            "activeOnStart": true,
            "beginsPattern": "tsx watch",
            "endsPattern": "Server is running on http://localhost:3000"
          }
        }
      ],
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "clear": false
      }
    },
    {
      "label": "Start Full Stack Dev Servers",
      "dependsOn": [
        "Start Frontend Dev Server",
        "Start Backend Dev Server"
      ],
      "dependsOrder": "parallel",
      "problemMatcher": []
    }
  ]
}
