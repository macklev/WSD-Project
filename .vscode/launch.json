{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Backend: Node + TSX",
      "type": "node",
      "request": "launch",
      "cwd": "${workspaceFolder}",
      "runtimeExecutable": "node",
      "runtimeArgs": ["--import", "tsx", "server/index.ts"],
      "console": "integratedTerminal",
      "skipFiles": ["<node_internals>/**"]
    },
    {
      "name": "Frontend: Vite Dev Server",
      "type": "node-terminal",
      "request": "launch",
      "cwd": "${workspaceFolder}/client",
      "command": "npm run dev"
    },
    {
      "name": "Frontend: Chrome",
      "type": "chrome",
      "request": "launch",
      "url": "http://localhost:5173",
      "webRoot": "${workspaceFolder}/client",
      "sourceMaps": true
    }
  ],
  "compounds": [
    {
      "name": "Full Stack: Backend + Frontend",
      "configurations": [
        "Backend: Node + TSX",
        "Frontend: Vite Dev Server",
        "Frontend: Chrome"
      ],
      "stopAll": true
    }
  ]
}
